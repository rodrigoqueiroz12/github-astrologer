# Gerado com: docker compose run --rm backend php artisan key:generate --show
APP_KEY=base64:

# Token GitHub — Fine-grained, Public repositories, Contents+Metadata read-only
# https://github.com/settings/tokens
GITHUB_API_KEY=ghp_

# Chave Gemini — plano gratuito suficiente
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
